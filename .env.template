# Google OAuth2 Configuration
# ===========================================
# Get these values from: https://console.cloud.google.com

# Google OAuth Client ID
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE.apps.googleusercontent.com

# Google OAuth Client Secret  
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# Application Redirect URI
# After user authorizes, Google will redirect to this URL
# Make sure this URL is registered in your Google Cloud Console
APPLICATION_REDIRECT_URI=http://localhost:8082/login/oauth2/code/google

