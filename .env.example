# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_URL=jdbc:postgresql://localhost:5432/banking_system
DB_USER=postgres
DB_PASSWORD=your_db_password

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
APPLICATION_REDIRECT_URI=http://localhost:8082/login/oauth2/code/google

# ============================================
# AI CHATBOT CONFIGURATION
# ============================================

# AI Provider: "openai" or "gemini"
AI_PROVIDER=openai

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# Format: sk-...
AI_API_KEY=sk-your_openai_api_key_here

# Model Name
# OpenAI options: gpt-4o-mini, gpt-4, gpt-3.5-turbo
# Gemini options: gemini-pro
AI_MODEL=gpt-4o-mini

# Maximum tokens in response
AI_MAX_TOKENS=500

# Temperature (0.0 = deterministic, 1.0 = creative)
AI_TEMPERATURE=0.7

# System prompt for the chatbot
AI_SYSTEM_PROMPT=You are a professional AI banking assistant for a Loan Management System. Only answer finance, loan, EMI, repayment, banking, and platform-related questions in a professional and concise way. Be helpful and accurate.

# ============================================
# ALTERNATIVE: Using Google Gemini API
# ============================================
# Uncomment below to use Gemini instead of OpenAI

# AI_PROVIDER=gemini
# AI_API_KEY=your_google_gemini_api_key_here
# AI_MODEL=gemini-pro
# AI_TEMPERATURE=0.7
